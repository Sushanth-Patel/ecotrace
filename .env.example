# ══════════════════════════════════════════════════════
#  EcoTrace — Environment Variables
#  Copy to .env for local dev. Never commit .env.
# ══════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────
PORT=3000
NODE_ENV=production
ALLOWED_ORIGINS=http://localhost:3000

# ── AI Provider ───────────────────────────────────────
AI_PROVIDER=gemini

# ── Google Gemini (FREE) ──────────────────────────────
# Get key: https://aistudio.google.com → Get API key
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash
